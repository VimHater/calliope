#load "prelude"

double x = x * 2

-- n is even when it leaves no remainder mod 2 (`/` is fractional, so use `mod`)
isEven n = mod n 2 == 0

-- add up a list of numbers
total xs = foldr (\x running -> x + running) 0 xs

-- keep the even numbers, double them, then sum the result
main = total (map double (filter isEven [1, 2, 3, 4, 5, 6]))
-- evens [2,4,6] -> doubled [4,8,12] -> 24
